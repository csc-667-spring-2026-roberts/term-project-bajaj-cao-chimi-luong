<% const title = "Game" %>
<%- include('layout', { title, body: `
<script src="/js/game.js" defer></script>
<div id="game-root">
<div id="opponent-area">
<div class="player-label">Opponent</div>
<div id="opponent-info"></div>
</div>
<div id="center-zone">
<div id="game-status"></div>
<div id="discard-zone">Discard</div>
</div>
<div id="deck-zone">
<div class="deck-stack" id="draw-deck"></div>
<div id="deck-count-label"></div>
<div style="display:flex;gap:10px;margin-top:8px;">
<button id="draw-button" disabled>Draw Card</button>
</div>
</div>
<div id="my-area">
<div class="player-label">Your hand</div>
<div id="my-info"></div>
<div id="my-hand"></div>
</div>
<div id="chat-box">
<div id="chat-messages"></div>
<div id="chat-input-row">
<input id="chat-input" type="text" placeholder="Say something..." maxlength="200" />
<button id="chat-send">Send</button>
</div>
</div>
</div>
<template id="player-state-card">
<div class="player-state">
<img class="player-avatar" src="" alt="" />
<div class="player-email"></div>
<div class="player-card-count"><span>0</span> cards</div>
</div>
</template>
<input type="hidden" id="GAME_ID" value="${gameId}" />
`, user }) %>