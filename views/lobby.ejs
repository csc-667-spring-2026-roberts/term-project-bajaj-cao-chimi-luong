<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Lobby</title>
  <script src="/js/lobby.js" defer></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0f0f11;
      --surface: #1a1a1f;
      --border: #2a2a32;
      --accent: #7c6af7;
      --text: #e8e8f0;
      --muted: #888899;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 2rem;
      border-bottom: 1px solid var(--border);
    }

    nav .logo {
      font-family: 'DM Serif Display', serif;
      font-size: 1.25rem;
    }

    main {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .lobby-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 3rem;
      max-width: 480px;
      width: 100%;
      text-align: center;
    }

    .avatar {
      width: 88px;
      height: 88px;
      border-radius: 50%;
      border: 3px solid var(--accent);
      margin: 0 auto 1.5rem;
      display: block;
    }

    .lobby-card h1 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.75rem;
      margin-bottom: 0.5rem;
    }

    .lobby-card .email {
      color: var(--muted);
      font-size: 0.9rem;
      margin-bottom: 0.5rem;
    }

    .lobby-card .joined {
      color: var(--muted);
      font-size: 0.8rem;
      margin-bottom: 2rem;
    }

    .divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 1.5rem 0;
    }

    form button {
      padding: 0.65rem 1.5rem;
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--muted);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.875rem;
      cursor: pointer;
      transition: border-color 0.2s, color 0.2s;
    }

    form button:hover {
      border-color: var(--accent);
      color: var(--text);
    }
  </style>
</head>
<body>
  <nav>
    <span>Exploding Kittens</span>
  </nav>
  <main>
    <div class="lobby-card">
      <img class="avatar" src="<%= user.gravatar_url %>" alt="Avatar" />
      <h1>Welcome back!</h1>
      <p class="email"><%= user.email %></p>
      <p class="joined">Member since <%= new Date(user.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>

      <hr class="divider" />

      <form method="post" action="/auth/logout">
        <button type="submit">Sign out</button>
      </form>
    </div>
     <% if (typeof error !== "undefined" && error) { %> 
            <div class="error">
                <%= error %>
            </div>
        <% } %>
            <h2>Lobby</h2>
        <section>
            <h3>Games</h3>
            <button id="create-game">Create Game</button>
            <div id="games-list">
                <p>Loading...</p>
            </div>

            <template id= "game-card-template">
                <div class="game-card">
                    <span data-game-id></span>
                    <span data-creator></span>
                    <span data-player-count></span>
                    <span data-status></span>
                    <form data-join method="post">
                      <button>Join</button>
                    </form>                    
                </div>
            </template>
        </section>
  </main>
</body>
</html>
