<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/style.css">
  <title>Lobby</title>
</head>

<body>
  <nav>
    <span class="logo">Exploding Kittens</span>
  </nav>
  <main>
    <div class="lobby-card">
      <img class="avatar" src="<%= user.gravatar_url %>" alt="Avatar" />
      <h1>Welcome back!</h1>
      <p class="email">
        <%= user.email %>
      </p>
      <p class="joined">Member since <%= new Date(user.created_at).toLocaleDateString('en-US', { year: 'numeric' ,
          month: 'long' , day: 'numeric' }) %>
      </p>
      <hr class="divider" />
      <form method="POST" action="/auth/logout">
        <button type="submit">Sign out</button>
      </form>
    </div>
  </main>
</body>

</html>